# Copy to .env (git-ignored). Twelve-Factor: all config comes from the environment.
POSTGRES_USER=oex
POSTGRES_PASSWORD=oex
POSTGRES_DB=openexchange
DATABASE_URL=postgresql://oex:oex@localhost:5432/openexchange

KAFKA_BOOTSTRAP=localhost:9092

REDIS_ADDR=localhost:6379

ENGINE_GRPC_ADDR=localhost:9090

# Gateway auth — generate a real secret for anything public.
JWT_SECRET=dev-only-change-me
